{
    "name": "@moso/eslint-config",
    "type": "module",
    "version": "2.0.5",
    "description": "My shareable ESLint config",
    "author": {
        "name": "Morten Sørensen",
        "email": "morten@moso.dev",
        "url": "https://moso.dev"
    },
    "license": "BSD-3-Clause",
    "homepage": "https://github.com/moso/eslint-config",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/moso/eslint-config/eslint-config.git"
    },
    "bugs": {
        "url": "https://github.com/moso/eslint-config/issues"
    },
    "keywords": [
        "config",
        "eslint",
        "eslint-config",
        "eslint-config moso",
        "functional programming",
        "moso",
        "perfectionist",
        "stylistic",
        "typescript",
        "react",
        "vue"
    ],
    "exports": {
        ".": "./dist/index.mjs",
        "./package.json": "./package.json"
    },
    "types": "./dist/index.d.mts",
    "files": [
        "./LICENSE",
        "./README.md",
        "./package.json",
        "dist/"
    ],
    "engines": {
        "node": "^20.19.0 || ^22.13.0 || >=24"
    },
    "scripts": {
        "build": "bun run typegen && tsdown --clean --dts",
        "build:inspector": "bun run build && bunx @eslint/config-inspector build",
        "dev": "bunx @eslint/config-inspector --config eslint.config.ts",
        "lint": "eslint",
        "prepack": "bun run build",
        "prepare": "bun run simple-git-hooks",
        "release": "bumpp && bun publish",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "typegen": "tsx scripts/typegen.ts",
        "watch": "tsdown --watch"
    },
    "workspaces": [
        "src/rules"
    ],
    "peerDependencies": {
        "@eslint-react/eslint-plugin": "^2.13.0",
        "@next/eslint-plugin-next": "^16.1.6",
        "astro-eslint-parser": "^1.3.0",
        "eslint": ">=9.30.0 || >= 10",
        "eslint-plugin-astro": "^1.6.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.2",
        "eslint-plugin-vuejs-accessibility": "^2.5.0"
    },
    "peerDependenciesMeta": {
        "@eslint-react/eslint-plugin": {
            "optional": true
        },
        "@next/eslint-plugin-next": {
            "optional": true
        },
        "astro-eslint-parser": {
            "optional": true
        },
        "eslint-plugin-astro": {
            "optional": true
        },
        "eslint-plugin-jsx-a11y": {
            "optional": true
        },
        "eslint-plugin-react-hooks": {
            "optional": true
        },
        "eslint-plugin-react-refresh": {
            "optional": true
        },
        "eslint-plugin-react-you-might-not-need-an-effect": {
            "optional": true
        },
        "eslint-plugin-vuejs-accessibility": {
            "optional": true
        }
    },
    "dependencies": {
        "@antfu/install-pkg": "^1.1.0",
        "@clack/prompts": "^1.1.0",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
        "@stylistic/eslint-plugin": "^5.9.0",
        "@typescript-eslint/eslint-plugin": "^8.56.1",
        "@typescript-eslint/parser": "^8.56.1",
        "@vitest/eslint-plugin": "^1.6.9",
        "eslint-flat-config-utils": "^3.0.1",
        "eslint-merge-processors": "^2.0.0",
        "eslint-plugin-de-morgan": "^2.1.1",
        "eslint-plugin-functional": "^9.0.4",
        "eslint-plugin-import-lite": "^0.5.2",
        "eslint-plugin-jsdoc": "^62.7.1",
        "eslint-plugin-jsonc": "^3.1.1",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-no-only-tests": "^3.3.0",
        "eslint-plugin-perfectionist": "^5.6.0",
        "eslint-plugin-promise": "^7.2.1",
        "eslint-plugin-regexp": "^3.0.0",
        "eslint-plugin-unicorn": "^63.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "eslint-plugin-yml": "^3.3.1",
        "eslint-processor-vue-blocks": "^2.0.0",
        "globals": "^17.4.0",
        "jsonc-eslint-parser": "^3.1.0",
        "local-pkg": "^1.1.2",
        "toml-eslint-parser": "^1.0.3",
        "vue-eslint-parser": "^10.4.0",
        "yaml-eslint-parser": "^2.0.0"
    },
    "devDependencies": {
        "@eslint-react/eslint-plugin": "^2.13.0",
        "@eslint/compat": "^2.0.2",
        "@eslint/config-inspector": "^1.5.0",
        "@eslint/js": "^10.0.1",
        "@moso/eslint-plugin": "workspace:*",
        "@next/eslint-plugin-next": "^16.1.6",
        "@types/node": "^25.3.3",
        "@typescript-eslint/rule-tester": "^8.56.1",
        "@typescript-eslint/utils": "^8.56.1",
        "astro-eslint-parser": "^1.3.0",
        "bumpp": "^10.4.1",
        "eslint": "^10.0.2",
        "eslint-plugin-astro": "^1.6.0",
        "eslint-plugin-erasable-syntax-only": "^0.4.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.2",
        "eslint-plugin-toml": "^1.3.1",
        "eslint-plugin-vue": "^10.8.0",
        "eslint-plugin-vuejs-accessibility": "^2.5.0",
        "eslint-typegen": "^2.3.1",
        "jiti": "^2.6.1",
        "lint-staged": "^16.3.2",
        "simple-git-hooks": "git+https://github.com/toplenboren/simple-git-hooks.git",
        "ts-dedent": "^2.2.0",
        "tsdown": "^0.20.3",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "simple-git-hooks": {
        "pre-commit": "bunx lint-staged"
    },
    "lint-staged": {
        "*": "eslint --fix"
    },
    "trustedDependencies": [
        "esbuild",
        "simple-git-hooks",
        "unrs-resolver"
    ]
}
