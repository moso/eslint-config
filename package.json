{
    "name": "@moso/eslint-config",
    "type": "module",
    "version": "3.0.3",
    "description": "@moso's sharable ESLint config",
    "author": {
        "name": "Morten Sørensen",
        "email": "morten@moso.dev",
        "url": "https://moso.dev"
    },
    "license": "BSD-3-Clause",
    "homepage": "https://github.com/moso/eslint-config",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/moso/eslint-config/eslint-config.git"
    },
    "bugs": {
        "url": "https://github.com/moso/eslint-config/issues"
    },
    "keywords": [
        "config",
        "eslint",
        "eslint-config",
        "eslint-config moso",
        "functional programming",
        "moso",
        "perfectionist",
        "stylistic",
        "typescript",
        "react",
        "vue"
    ],
    "exports": {
        ".": "./dist/index.mjs",
        "./package.json": "./package.json"
    },
    "types": "./dist/index.d.mts",
    "files": [
        "./LICENSE",
        "./README.md",
        "./package.json",
        "dist/"
    ],
    "engines": {
        "node": "^22.22.3 || >=24"
    },
    "scripts": {
        "build": "bun run typegen && tsdown --clean --dts",
        "build:inspector": "bun run build && bunx @eslint/config-inspector build --config eslint.config.ts --out-dir ./.eslint-config-inspector",
        "dev": "bunx @eslint/config-inspector --config eslint.config.ts",
        "lint": "eslint",
        "prepack": "bun run build",
        "prepare": "bun run simple-git-hooks",
        "release": "bumpp --recursive && bun publish",
        "test": "vitest run",
        "test:update-snapshots": "vitest --update",
        "typecheck": "tsc --noEmit",
        "typegen": "tsx scripts/typegen.ts",
        "watch": "tsdown --watch"
    },
    "workspaces": [
        "src/rules"
    ],
    "peerDependencies": {
        "@eslint-react/eslint-plugin": "^5.14.8",
        "@next/eslint-plugin-next": "^16.2.10",
        "astro-eslint-parser": "^3.0.0",
        "eslint": "^10.0.0",
        "eslint-plugin-astro": "^3.0.0",
        "eslint-plugin-erasable-syntax-only": "^0.4.2",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.1",
        "eslint-plugin-vue": "^10.9.2",
        "eslint-plugin-vuejs-accessibility": "^2.5.0",
        "typescript": "^6.0.0"
    },
    "peerDependenciesMeta": {
        "@eslint-react/eslint-plugin": {
            "optional": true
        },
        "@next/eslint-plugin-next": {
            "optional": true
        },
        "astro-eslint-parser": {
            "optional": true
        },
        "eslint-plugin-astro": {
            "optional": true
        },
        "eslint-plugin-erasable-syntax-only": {
            "optional": true
        },
        "eslint-plugin-jsx-a11y": {
            "optional": true
        },
        "eslint-plugin-react-hooks": {
            "optional": true
        },
        "eslint-plugin-react-refresh": {
            "optional": true
        },
        "eslint-plugin-react-you-might-not-need-an-effect": {
            "optional": true
        },
        "eslint-plugin-vue": {
            "optional": true
        },
        "eslint-plugin-vuejs-accessibility": {
            "optional": true
        },
        "typescript": {
            "optional": true
        }
    },
    "dependencies": {
        "@antfu/install-pkg": "^1.1.0",
        "@clack/prompts": "^1.7.0",
        "@e18e/eslint-plugin": "^0.5.1",
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@typescript-eslint/eslint-plugin": "^8.64.0",
        "@typescript-eslint/parser": "^8.64.0",
        "@typescript-eslint/utils": "^8.64.0",
        "@vitest/eslint-plugin": "^1.6.23",
        "eslint-config-flat-gitignore": "^2.3.0",
        "eslint-flat-config-utils": "^3.2.0",
        "eslint-merge-processors": "^2.0.0",
        "eslint-plugin-de-morgan": "^2.1.3",
        "eslint-plugin-functional": "^10.0.0",
        "eslint-plugin-import-lite": "^0.6.0",
        "eslint-plugin-jsdoc": "^63.0.13",
        "eslint-plugin-jsonc": "^3.3.0",
        "eslint-plugin-n": "^18.2.2",
        "eslint-plugin-no-only-tests": "^3.4.0",
        "eslint-plugin-perfectionist": "^5.10.0",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-regexp": "^3.1.1",
        "eslint-plugin-toml": "^1.4.0",
        "eslint-plugin-unicorn": "^71.1.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "eslint-plugin-yml": "^3.6.0",
        "eslint-processor-vue-blocks": "^2.0.0",
        "globals": "^17.7.0",
        "jsonc-eslint-parser": "^3.1.0",
        "local-pkg": "^1.2.1",
        "toml-eslint-parser": "^1.0.3",
        "vue-eslint-parser": "^10.4.1",
        "yaml-eslint-parser": "^2.1.0"
    },
    "devDependencies": {
        "@eslint-react/eslint-plugin": "^5.14.8",
        "@eslint/compat": "^2.1.0",
        "@eslint/config-inspector": "^3.1.0",
        "@moso/eslint-plugin": "workspace:*",
        "@next/eslint-plugin-next": "^16.2.10",
        "@types/eslint-plugin-jsx-a11y": "^6.10.1",
        "@types/node": "^26.1.1",
        "@typescript-eslint/rule-tester": "^8.64.0",
        "astro-eslint-parser": "^3.0.0",
        "bumpp": "^11.1.0",
        "eslint": "^10.7.0",
        "eslint-plugin-astro": "^3.0.0",
        "eslint-plugin-erasable-syntax-only": "^0.4.2",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.1",
        "eslint-plugin-vue": "^10.9.2",
        "eslint-plugin-vuejs-accessibility": "^2.5.0",
        "eslint-typegen": "^2.3.1",
        "jiti": "^2.7.0",
        "nano-staged": "^1.0.2",
        "simple-git-hooks": "^2.13.1",
        "ts-dedent": "^2.3.0",
        "tsdown": "^0.22.7",
        "tsx": "^4.23.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.10"
    },
    "simple-git-hooks": {
        "pre-commit": "bunx nano-staged"
    },
    "nano-staged": {
        "*": "eslint --fix"
    }
}
