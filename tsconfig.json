{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "paths": {
            "@/perfectionist-types/*": ["./node_modules/eslint-plugin-perfectionist/dist/types/*"]
        },
        "types": ["eslint-plugin-jsx-a11y", "node", "vitest/config"],
        "strict": true,
        "declaration": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedDeclarations": true
    },
    "include": ["**/*.ts"]
}
